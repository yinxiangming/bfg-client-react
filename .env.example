# API base URL (required). No trailing slash.
NEXT_PUBLIC_API_URL=

# Platform login URL. Set if this workspace is managed by a Platform instance.
# When set, the workspace /auth/login page redirects here automatically.
# Leave unset for standalone workspaces that manage their own login.
# NEXT_PUBLIC_PLATFORM_LOGIN_URL=https://platform.example.com/auth/login

# Optional: workspace ID for multi-tenant setups.
# - Workspace instances: set this to bind the frontend to a specific workspace (e.g. 1)
# - Platform instances: leave unset; workspace ID comes from Token Exchange / localStorage
# NEXT_PUBLIC_WORKSPACE_ID=1

# Optional: comma-separated plugin ids to enable (default: all under src/plugins)
# ENABLED_PLUGINS=resale
# NEXT_PUBLIC_ENABLED_PLUGINS=resale

# Optional: Google Maps for address autocomplete
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: media base URL (default: NEXT_PUBLIC_API_URL + /media)
# NEXT_PUBLIC_MEDIA_URL=http://localhost:8000/media
